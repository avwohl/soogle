# Soogle environment configuration.
# Copy to .env and fill in real values.  Sourced by Django, the scrape CLI,
# and weekly.bash.

# --- Database ---
SOOGLE_DB_HOST=127.0.0.1
SOOGLE_DB_PORT=3306
SOOGLE_DB_USER=root
SOOGLE_DB_PASS=changeme
SOOGLE_DB_NAME=soogle

# --- API keys (optional, depending on which scrapers you run) ---
GH_TOKEN=
BRAVE_API_KEY=
SERPAPI_KEY=
BING_API_KEY=
ANTHROPIC_API_KEY=

# --- hCaptcha (used by /submit/ form) ---
HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=

# --- Email notifications for new site submissions ---
SUBMISSION_EMAIL_TO=
SUBMISSION_EMAIL_FROM=noreply@soogle.org
EMAIL_HOST=localhost
EMAIL_PORT=25
